
# PDF files — too large for git; serve via local static folder or copy manually to programs/*/pdfs/
programs/*/pdfs/*.pdf

# Static PDF symlinks — broken on Community Cloud (PDFs not deployed); keep local only
dashboard/static/pdfs/

# macOS metadata
.DS_Store
**/.DS_Store

# Python cache
__pycache__/
*.pyc
*.pyo

# Scraper HTML cache (scripts/scrape_uu_supervisors.py)
.cache/

# Streamlit-generated embedded HTML cache (created at runtime beside the script)
/static/

# Large local thesis archives and documents
programs/*/pdfs/**/*.pdf
programs/*/pdfs/**/*.docx
programs/*/pdfs/**/*.zip
programs/*/pdfs/*.zip
